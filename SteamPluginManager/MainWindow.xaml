<Window x:Class="SteamPluginManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Steam Plugin Manager" Height="600" Width="900"
        Background="#1E1E1E" Foreground="#FFFFFF"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <StackPanel Margin="20">
            <!-- Header -->
            <TextBlock Text="🎮 Steam Plugin Manager" FontSize="28" FontWeight="Bold" 
                       Margin="0,0,0,10" Foreground="#00D4FF"/>
            <TextBlock Text="Plugin dosyalarından oyunları Steam kütüphanesine ekleyin" 
                       FontSize="12" Foreground="#808080" Margin="0,0,0,20"/>

            <!-- Plugin Listesi -->
            <TextBlock Text="Available Plugins" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
            
            <DataGrid x:Name="PluginGrid" Height="350" Margin="0,0,0,15" 
                      AutoGenerateColumns="False" Background="#2D2D2D" Foreground="#FFFFFF"
                      BorderBrush="#404040" RowBackground="#2D2D2D" AlternatingRowBackground="#252525">
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn Header="✓" Binding="{Binding Enabled}" Width="40"/>
                    <DataGridTextColumn Header="Game Name" Binding="{Binding Name}" Width="200"/>
                    <DataGridTextColumn Header="Path" Binding="{Binding LaunchPath}" Width="300"/>
                    <DataGridTextColumn Header="Executable" Binding="{Binding Executable}" Width="150"/>
                    <DataGridTextColumn Header="Version" Binding="{Binding Version}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Butonlar -->
            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                <Button x:Name="AddBtn" Content="➕ Add to Steam" Click="AddBtn_Click" 
                        Padding="15,10" Margin="0,0,10,0" Background="#00AA00" Foreground="White"
                        FontSize="12" FontWeight="Bold" Cursor="Hand"/>
                <Button x:Name="RemoveBtn" Content="❌ Remove from Steam" Click="RemoveBtn_Click" 
                        Padding="15,10" Margin="0,0,10,0" Background="#FF4444" Foreground="White"
                        FontSize="12" FontWeight="Bold" Cursor="Hand"/>
                <Button x:Name="RefreshBtn" Content="🔄 Refresh" Click="RefreshBtn_Click" 
                        Padding="15,10" Background="#0066FF" Foreground="White"
                        FontSize="12" FontWeight="Bold" Cursor="Hand"/>
            </StackPanel>

            <!-- Status -->
            <TextBlock x:Name="StatusText" Text="Ready" FontSize="11" Foreground="#808080" 
                       Margin="0,15,0,0"/>
        </StackPanel>
    </Grid>
</Window>
